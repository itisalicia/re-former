<h1> New user </h1>
<form accept-charset="UTF-8" action="/users" method="post" data-turbo="false">
    <input
    type="hidden"
    name="authenticity_token"
    value="<%= form_authenticity_token %>"
    >


    <div>
        <label for="username"> Username: </label>
        <input id="username" name="user[username]" type="text">
    </div>
    <div>
        <label for="email"> Email: </label>
        <input id="email" name="user[email]" type="email">
    </div>
    <div>
        <label for="password"> Password: </label>
        <input id="password" name="user[password]" type="password">
    </div>

  <input type="submit" value="submit">

</form>
